<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- Required metadata -->
  <Id>CA2024-ALIBI-WORD-PLUGIN-7C3AED10</Id>
  <Version>2.0.0.0</Version>
  <ProviderName>Creative Alibi</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Creative Alibi" />
  <Description DefaultValue="Authenticity Companion for Content Creators — Powered by IBM Granite" />

  <!-- Icons -->
  <IconUrl DefaultValue="http://localhost:3000/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="http://localhost:3000/assets/icon-64.png" />
  <SupportUrl DefaultValue="https://creative-alibi.app/support" />

  <!-- Permissions -->
  <Permissions>ReadWriteDocument</Permissions>

  <!-- Supported products -->
  <Hosts>
    <Host Name="Document" />
  </Hosts>

  <!-- Default settings -->
  <DefaultSettings>
    <SourceLocation DefaultValue="http://localhost:3000/index.html" />
  </DefaultSettings>

  <!-- Version overrides for ribbon and enhanced features -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <!-- Ribbon buttons -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="creative.alibi.group">
                <Label resid="alibi.GroupLabel" />

                <!-- Main Task Pane button -->
                <Control xsi:type="Button" id="creative.alibi.showTaskpane">
                  <Label resid="alibi.Button.Label" />
                  <Supertip>
                    <Title resid="alibi.Button.Label" />
                    <Description resid="alibi.Button.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="alibi.Icon.16x16" />
                    <bt:Image size="32" resid="alibi.Icon.32x32" />
                    <bt:Image size="80" resid="alibi.Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>Office.AutoShowTaskpaneWithDocument</TaskpaneId>
                    <SourceLocation resid="alibi.TaskpaneUrl" />
                  </Action>
                </Control>

                <!-- Quick AI Partner button -->
                <Control xsi:type="Button" id="creative.alibi.quickAI">
                  <Label resid="alibi.QuickAI.Label" />
                  <Supertip>
                    <Title resid="alibi.QuickAI.Label" />
                    <Description resid="alibi.QuickAI.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="alibi.Icon.16x16" />
                    <bt:Image size="32" resid="alibi.Icon.32x32" />
                    <bt:Image size="80" resid="alibi.Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>Office.AutoShowTaskpaneWithDocument</TaskpaneId>
                    <SourceLocation resid="alibi.TaskpaneUrl" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- Task Pane definition (350px width) -->
          <ExtensionPoint xsi:type="CustomPane">
            <OfficeTab id="TabDefault"/>
            <Location resid="alibi.TaskpaneUrl"/>
            <SupportedSize MinRowCount="1" MinColumnCount="2"/>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <!-- String resources -->
    <Resources>
      <bt:Images>
        <bt:Image id="alibi.Icon.16x16" DefaultValue="http://localhost:3000/assets/icon-16.png" />
        <bt:Image id="alibi.Icon.32x32" DefaultValue="http://localhost:3000/assets/icon-32.png" />
        <bt:Image id="alibi.Icon.80x80" DefaultValue="http://localhost:3000/assets/icon-80.png" />
      </bt:Images>

      <bt:Urls>
        <bt:Url id="alibi.TaskpaneUrl" DefaultValue="http://localhost:3000/index.html" />
      </bt:Urls>

      <bt:ShortStrings>
        <bt:String id="alibi.GroupLabel" DefaultValue="Creative Alibi" />
        <bt:String id="alibi.Button.Label" DefaultValue="Open Alibi" />
        <bt:String id="alibi.QuickAI.Label" DefaultValue="AI Partner" />
      </bt:ShortStrings>

      <bt:LongStrings>
        <bt:String id="alibi.Button.Tooltip" DefaultValue="Open Creative Alibi: Authenticity Companion — Track your writing process and generate an Authenticity Report powered by IBM Granite." />
        <bt:String id="alibi.QuickAI.Tooltip" DefaultValue="Open IBM Granite AI Creative Partner — get style suggestions, brainstorming help, and grammar assistance. All interactions are logged for transparency." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
