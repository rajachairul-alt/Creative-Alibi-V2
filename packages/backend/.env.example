# IBM watsonx.ai Configuration
WATSONX_API_KEY=your-ibm-cloud-api-key-here
WATSONX_PROJECT_ID=your-watsonx-project-id-here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_IAM_URL=https://iam.cloud.ibm.com/identity/token

# IBM Granite Model Configuration
GRANITE_MODEL_ID=ibm/granite-3-3b-instruct
GRANITE_FALLBACK_MODEL_ID=ibm/granite-3-8b-instruct

# Hugging Face (for desklib AI-text detector — called once per report only)
HUGGINGFACE_API_KEY=your-huggingface-api-token-here

# Backend Server
PORT=3001
NODE_ENV=development
HOST=0.0.0.0

# Security — generate with: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here
JWT_SECRET=your-jwt-secret-here

# CORS — allowed origins for Word plugin and web dashboard
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI Creative Partner settings
GRANITE_MAX_TOKENS=300
GRANITE_TIMEOUT_MS=30000

# Detector settings (CRITICAL: never increase DETECTOR_MAX_CALLS above 1)
DETECTOR_MAX_CALLS_PER_SESSION=1
